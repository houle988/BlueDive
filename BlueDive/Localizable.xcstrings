    },
    "\n… %lld more lines. Use Copy or Save As for full content." : {
      "comment" : "A note displayed below the UDDF preview, indicating that the content has been truncated and providing instructions on how to view the full content.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n… %lld lignes de plus. Utilisez Copier ou Enregistrer sous pour le contenu complet."
          }
        }
      }
    },
    "–" : {
      "comment" : "A placeholder text for the minimum depth filter field.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "—" : {
      "comment" : "A placeholder text used when a temperature reading is unavailable.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "," : {
      "comment" : "A comma.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    ", " : {
      "comment" : "A conjunction used to join two independent clauses, such as \"I like ice cream, and you like cake.\"",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    ": %@" : {
      "comment" : "A label displaying a color-coded row in a dive metric legend. The argument is the string “—”, the string “%1$arg-%2$arg”, the string “%1$arg-%2$arg %3$arg” or the string “%1$.0f-%2$.0f min”.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "·" : {
      "comment" : "A period used to separate two related pieces of information.",
      "isCommentAutoGenerated" : true,
      "shouldTranslate" : false
    },
    "\"%@\" will be permanently deleted. All associated data (fish sightings, equipment) will also be deleted." : {
      "comment" : "A confirmation alert for deleting a single dive. The argument is the name of the dive to be deleted.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" will be permanently deleted. All associated data (fish sightings, equipment) will also be deleted."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" sera supprimé définitivement. Toutes les données associées (observations de poissons, équipement) seront également supprimées."
          }
        }
      }
    },
    "*" : {
      "comment" : "An asterisk used to indicate a required field in a form.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "*"
