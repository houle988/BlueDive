      "localizations" : {
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BlueDive est strictement une application de carnet de plongée conçue pour enregistrer et organiser votre historique de plongée. Ce n'est pas un outil de planification de plongée et ne doit jamais être utilisé comme tel."
          }
        }
